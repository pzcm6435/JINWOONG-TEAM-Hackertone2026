\# Render dashboard > Postgres (dpg-d9bbvn6q1p3s73aooib0-a) > Connections
\# Copy the "External Database URL" for local dev, or the "Internal Database URL"
\# when this API itself runs as a Render Web Service in the same account/region.
DATABASE_URL=postgresql://user:password@host/dbname

PORT=4000

\# --- Vertex AI model (optional) ---
\# Google Cloud > Vertex AI > Model Registry > voice_check_dataset > Deploy & test
\# > Sample Request > REST, then build the predict URL from the endpoint ID shown there:
\# https://{REGION}-aiplatform.googleapis.com/v1/projects/{PROJECT_NUMBER}/locations/{REGION}/endpoints/{ENDPOINT_ID}:predict
\# Leave unset to run on the built-in heuristic fallback (no GCP cost).
MODEL_ENDPOINT_URL=

\# Auth: locally, `gcloud auth application-default login` is enough (uses your
\# own Google login). On Render, create a service account with the
\# "Vertex AI User" role, download its JSON key, and paste the whole JSON as
\# one line into this variable instead.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
